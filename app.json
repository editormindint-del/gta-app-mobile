{
  "expo": {
    "name": "Visit Gauteng",
    "slug": "visit-gauteng",
    "version": "3.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "visitgauteng",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.visitgp.app",
      "buildNumber": "12",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "package": "com.wnapp.visitgp",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#111111",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#111111",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "402c660c-5caa-4e9b-a058-6e270fb69e5b"
      }
    },
    "owner": "visitgauteng",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/402c660c-5caa-4e9b-a058-6e270fb69e5b"
    }
  }
}
